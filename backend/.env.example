# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-key-here

# Android SDK path — find with: echo $ANDROID_HOME or check ~/Android/Sdk
ANDROID_SDK_ROOT=/home/you/Android/Sdk

# AVD directory — find with: ls ~/.android/avd/
# Flatpak Android Studio: ~/.var/app/com.google.AndroidStudio/config/.android/avd/
ANDROID_AVD_HOME=/home/you/.android/avd

# Base AVD name — must match an AVD created in Android Studio (folder name without .avd)
BASE_AVD_NAME=Pixel_9_Pro_XL
